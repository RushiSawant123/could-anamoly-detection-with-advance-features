# Cloud Anomaly Detection - Environmental Configuration
# Copy this file to '.env' and modify as needed.

# ============================================================================
# API CONNECTION
# ============================================================================
# Use 'http://127.0.0.1:8000/predict' for local testing.
# Use your ngrok or cloud URL when running across networks.
API_URL=http://127.0.0.1:8000/predict
API_HOST=127.0.0.1
API_PORT=8000
API_PROTOCOL=http

# ============================================================================
# DASHBOARD SETTINGS
# ============================================================================
REFRESH_INTERVAL=5000
RECORDS_TO_DISPLAY=10
API_TIMEOUT=10

# ============================================================================
# ANOMALY THRESHOLDS
# ============================================================================
ANOMALY_CRITICAL_THRESHOLD=0.7
ANOMALY_WARNING_THRESHOLD=0.4
ANOMALY_INFO_THRESHOLD=0.2
